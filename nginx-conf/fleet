# Redirect HTTP requests (port 80) to HTTPS
server {
    listen 80;
    server_name <YOUR_VPS_IP> fleetiqlogistics.com www.fleetiqlogistics.com;

    location / {
        return 301 https://fleetiqlogistics.com$request_uri;
    }

    # managed by Certbot
}

# Redirect HTTPS requests to the correct domain if accessed via IP
server {
    listen 443 ssl;
    server_name <YOUR_VPS_IP>;

    ssl_certificate /etc/letsencrypt/live/fleetiqlogistics.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/fleetiqlogistics.com/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    return 301 https://fleetiqlogistics.com$request_uri;
}

# Main HTTPS server block for your domain
server {
    listen 443 ssl;
    server_name fleetiqlogistics.com www.fleetiqlogistics.com;

    # API proxy
    location /api/ {
        proxy_pass http://localhost:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

        # CORS headers
        add_header 'Access-Control-Allow-Origin' '*';
        add_header 'Access-Control-Allow-Methods' 'GET, POST, OPTIONS';
        add_header 'Access-Control-Allow-Headers' 'DNT,User-Agent,X-Requested-With,If-Modified-Since,Cache-Control,Content-Type,Range';
        add_header 'Access-Control-Expose-Headers' 'Content-Length,Content-Range';
    }

    # Uploads proxy
    location /uploads/ {
        proxy_pass http://localhost:8000/uploads/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    # Static frontend
    location / {
        root /var/www/html;
        index index.html index.htm;
        try_files $uri $uri/ /index.html;
    }

    # SSL config
    ssl_certificate /etc/letsencrypt/live/fleetiqlogistics.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/fleetiqlogistics.com/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
}
