# Server
PORT=8000

# MongoDB
MONGO_URL=mongodb://localhost:27017/FleetIQ

# JWT
JWT_SECRET=your_jwt_secret_here

# Email (Resend — https://resend.com/api-keys)
RESEND_API_KEY=re_REPLACE_ME
# EMAIL_FROM must be a verified sender domain in your Resend dashboard.
# Emails are silently skipped if RESEND_API_KEY is not set.
EMAIL_FROM=FleetIQ <noreply@fleetiqlogistics.com>

# # Stripe — Subscriptions (SaaS billing)
# # STRIPE_SECRET_KEY=sk_test_REPLACE_ME
# # STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# # Stripe Price IDs (create in Stripe Dashboard)
# STRIPE_PRICE_STARTER_MONTHLY=price_REPLACE_ME   # $99/mo
# STRIPE_PRICE_STARTER_ANNUAL=price_REPLACE_ME    # $948/yr
# STRIPE_PRICE_GROWTH_MONTHLY=price_REPLACE_ME    # $199/mo
# STRIPE_PRICE_GROWTH_ANNUAL=price_REPLACE_ME     # $1,908/yr
# STRIPE_PRICE_PRO_MONTHLY=price_REPLACE_ME       # $349/mo
# STRIPE_PRICE_PRO_ANNUAL=price_REPLACE_ME        # $3,348/yr

# Frontend URL (for Stripe redirects)
CLIENT_URL=http://localhost:5173

# Daily Digest Email — comma-separated section keys to include in every org's digest.
# Leave blank to enable all sections. Per-org overrides stored in Organization.digestSections take precedence.
# Available keys: warranties,maintenance_overdue,maintenance_upcoming,pm_overdue,pm_due_soon,
#                 insurance,registration,vehicles_oos,driver_licences,parts_low_stock
DIGEST_DEFAULT_SECTIONS=

# AI Chat Assistant (https://platform.openai.com/api-keys)
# Leave blank to disable the chat widget
OPENAI_API_KEY=

# HERE Geocoding API — IFTA jurisdiction detection
# Sign up free at https://developer.here.com (250k requests/month free tier)
HERE_API_KEY=D3JVuNnTMdecAExYaMLJo3gKzYN5mq90jiDFj8pfoLE