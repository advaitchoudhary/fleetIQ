# Server
PORT=8000

# MongoDB
MONGO_URL=mongodb://localhost:27017/FleetManagement

# JWT
JWT_SECRET=your_jwt_secret_here

# Email (Resend — https://resend.com/api-keys)
RESEND_API_KEY=re_LmPx3pWR_H8xc8wp6gb9U9oHJBh8jnmFJ
# EMAIL_FROM must be a verified sender domain in your Resend dashboard.
# Emails are silently skipped if RESEND_API_KEY is not set.
EMAIL_FROM=FleetIQ <noreply@yourdomain.com>

# # Stripe — Payments (Stripe Connect for driver payouts)
# # STRIPE_SECRET_KEY=sk_test_REPLACE_ME
# # STRIPE_CONNECT_WEBHOOK_SECRET=pk_live_REPLACE_ME

# # Stripe — Subscriptions (SaaS billing)
# # STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# # Stripe Price IDs (create in Stripe Dashboard)
# STRIPE_PRICE_DRIVER_MONTHLY=price_REPLACE_ME
# STRIPE_PRICE_DRIVER_ANNUAL=price_REPLACE_ME
# STRIPE_PRICE_VEHICLE_MONTHLY=price_REPLACE_ME
# STRIPE_PRICE_VEHICLE_ANNUAL=price_REPLACE_ME
# STRIPE_PRICE_BUNDLE_MONTHLY=price_REPLACE_ME
# STRIPE_PRICE_BUNDLE_ANNUAL=price_REPLACE_ME

# Frontend URL (for Stripe redirects)
CLIENT_URL=http://localhost:5173

# Daily Digest Email — comma-separated section keys to include in every org's digest.
# Leave blank to enable all sections. Per-org overrides stored in Organization.digestSections take precedence.
# Available keys: warranties,maintenance_overdue,maintenance_upcoming,pm_overdue,pm_due_soon,
#                 insurance,registration,vehicles_oos,driver_licences,parts_low_stock
DIGEST_DEFAULT_SECTIONS=

# AI Chat Assistant (https://platform.openai.com/api-keys)
# Leave blank to disable the chat widget
OPENAI_API_KEY=